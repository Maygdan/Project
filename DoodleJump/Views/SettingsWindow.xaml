<Window x:Class="DoodleJump.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="450" Width="400"
        WindowStartupLocation="CenterOwner" Background="#FF0D1A14">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="НАСТРОЙКИ" FontSize="30" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="ФОРМАТ СОХРАНЕНИЯ" Foreground="White" Opacity="0.7"/>
            <ComboBox x:Name="ComboFormat" Margin="0,5,0,20" SelectionChanged="ComboFormat_SelectionChanged">
                <ComboBoxItem Content="JSON"/>
                <ComboBoxItem Content="XML"/>
            </ComboBox>

            <TextBlock Text="ПАПКА ДАННЫХ" Foreground="White" Opacity="0.7"/>
            <DockPanel Margin="0,5,0,30">
                <Button Content="..." Width="40" Click="BtnBrowse_Click" Style="{StaticResource HollowButton}" DockPanel.Dock="Right"/>
                <TextBox x:Name="TxtSavePath" IsReadOnly="True" Background="#11FFFFFF" Foreground="White" VerticalContentAlignment="Center"/>
            </DockPanel>

            <Button Content="СОХРАНИТЬ И ВЫЙТИ" Click="BtnSave_Click" Style="{StaticResource HollowButton}"/>
        </StackPanel>
    </Grid>
</Window>